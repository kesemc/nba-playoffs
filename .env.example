# ==========================
# NBA Playoffs — env template
# Copy to `.env.local` (gitignored) and fill in real values.
# ==========================

# ---- Database ----
# Local dev (SQLite):
DATABASE_URL="file:./dev.db"
# Production (Neon Postgres) will look like:
# DATABASE_URL="postgresql://user:password@host/dbname?sslmode=require"

# ---- Auth.js v5 ----
# Base URL (Auth.js v5 infers from request in most cases, but set explicitly in prod)
AUTH_URL="http://localhost:3000"
# Long random string; generate with: openssl rand -base64 32
AUTH_SECRET="replace-me-with-a-long-random-string"

# ---- Google OAuth ----
# Create OAuth 2.0 credentials at https://console.cloud.google.com/apis/credentials
# See README for the step-by-step walkthrough. Authorized redirect URI(s):
#   http://localhost:3000/api/auth/callback/google   (for local dev)
#   https://<your-vercel-url>/api/auth/callback/google   (for prod)
AUTH_GOOGLE_ID=""
AUTH_GOOGLE_SECRET=""

# ---- Access control ----
# Comma-separated allow-list of email addresses that may sign in.
# Anyone outside this list gets rejected at sign-in time.
# Leave empty in dev to allow any email.
ALLOWED_EMAILS=""

# Optional: contact info shown to rejected sign-in attempts so they know
# how to reach you (email, phone, Telegram handle — whatever). If empty,
# we just say "please contact the pool admin".
POOL_ADMIN_CONTACT=""

# ---- Results provider (future) ----
# "manual" (default) reads from SeriesResult table filled in by admin.
# Other values reserved for future API-backed providers.
RESULTS_PROVIDER="manual"

# ---- Prize pool (optional, display only) ----
# If POOL_ENTRY_FEE is set to a positive number, the dashboard shows a
# prize-pool card with the pot size and payout breakdown (55/25/10 top three
# + 10% Red Lantern for last place). The app never moves real money — this
# is pure display, cash is handled between friends.
#
# Leave POOL_ENTRY_FEE empty to hide the pool UI entirely.
POOL_ENTRY_FEE=""
POOL_CURRENCY_SYMBOL="₪"
# Optional override: if set, this value is used as the number of entrants
# for pot calculations. If empty, the app counts all registered users.
POOL_PLAYER_COUNT=""
